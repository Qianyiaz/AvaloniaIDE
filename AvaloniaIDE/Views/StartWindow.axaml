<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaIDE.ViewModels"
        xmlns:views="using:AvaloniaIDE.Views"
        x:Class="AvaloniaIDE.Views.StartWindow"
        x:DataType="vm:StartWindowViewModel"
        Title="AvaloniaIDE"
        Icon="../app.ico">

    <Window.Styles>
        <Style Selector="ListBoxItem">
            <Setter Property="CornerRadius" Value="{DynamicResource OverlayCornerRadius}" />
            <Setter Property="Background" Value="{DynamicResource SystemControlTransientBackgroundBrush}" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="250,4,*">
        <Grid ColumnSpacing="8" Margin="35 25 0 0" VerticalAlignment="Top" HorizontalAlignment="Left"
              ColumnDefinitions="Auto,Auto">
            <Image Height="55" Width="55" Source="../app.ico" />

            <StackPanel VerticalAlignment="Center" Grid.Column="1">
                <TextBlock Text="AvaloniaIDE" />
                <SelectableTextBlock Foreground="{DynamicResource SystemControlDescriptionTextForegroundBrush}"
                                     Text="v1.0.0" />
            </StackPanel>
        </Grid>

        <Border Grid.Column="1" Background="{DynamicResource SystemControlTransientBackgroundBrush}" />

        <Grid RowSpacing="5" Margin="8" HorizontalAlignment="Stretch" RowDefinitions="Auto,*,Auto" Grid.Column="2">
            <Grid ColumnSpacing="5" ColumnDefinitions="*,Auto">
                <AutoCompleteBox Watermark="Search your projects" />

                <Button Grid.Column="1" Content="Open Sln File">
                    <Interaction.Behaviors>
                        <ButtonOpenFilePickerBehavior
                            Title="Open a File"
                            AllowMultiple="False"
                            FileTypeFilter="Solution Files|*.sln;*.slnx"
                            Command="{Binding OpenCommand}" />
                    </Interaction.Behaviors>
                </Button>
            </Grid>

            <ListBox Grid.Row="1" ItemsSource="{Binding Items}" Background="Transparent" SelectionMode="Toggle">
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="views:ProjectItem">
                        <Grid ColumnSpacing="8" ColumnDefinitions="Auto,Auto">
                            <Image Height="45" Width="45" Source="{Binding ImageSource}" />

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Vertical">
                                <TextBlock Text="{Binding Name}" />
                                <TextBlock Foreground="{DynamicResource SystemControlDescriptionTextForegroundBrush}"
                                           Text="{Binding Path}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <CheckBox Grid.Row="2" Content="Auto-open last sln" />
        </Grid>
    </Grid>
</Window>